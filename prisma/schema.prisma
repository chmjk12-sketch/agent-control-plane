generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  image     String?
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at")

  executions AgentExecution[]
}

model Agent {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  description         String?
  status              String   @default("offline")
  model               String   @default("deepseek-chat")
  tags                String   @default("[]")
  icon                String   @default("bot")
  endpoint            String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // V2.0 新增字段
  environmentSlot     String   @default("blue") @map("environment_slot")
  trafficWeight       Int      @default(100) @map("traffic_weight")
  deployStrategy      String   @default("blue-green") @map("deploy_strategy")
  healthCheckPath     String   @default("/health") @map("health_check_path")
  healthCheckInterval Int      @default(30) @map("health_check_interval")
  containerName       String?  @map("container_name")
  internalPort        Int      @default(3000) @map("internal_port")
  registryImage       String?  @map("registry_image")
  maxCostBudget       Float    @default(0) @map("max_cost_budget")
  apiKeyHash          String?  @map("api_key_hash")

  // V3.0 新增字段
  templateId       String?   @map("template_id")
  template         Template? @relation(fields: [templateId], references: [id])
  mcpEnabled       Boolean   @default(false) @map("mcp_enabled")
  mcpToolsEndpoint String?   @map("mcp_tools_endpoint")

  versions       AgentVersion[]
  deployments    Deployment[]
  executions     AgentExecution[]
  health         AgentHealth[]
  healthCheckLogs HealthCheckLog[]
  alerts         Alert[]
  alertRules     AlertRule[]
  apiKeys        ApiKey[]
  agentTemplates   AgentTemplate[]
  mcpTools         McpTool[]
  workflowNodes    WorkflowNode[]
}

model AgentVersion {
  id         String   @id @default(cuid())
  agentId    String   @map("agent_id")
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  versionTag String   @map("version_tag")
  codeRef    String?  @map("code_ref")
  promptRef  String?  @map("prompt_ref")
  modelRef   String?  @map("model_ref")
  toolConfig String?  @map("tool_config")
  envVars    String?  @map("env_vars")
  imageTag   String?  @map("image_tag")
  gitCommit  String?  @map("git_commit")
  changelog  String?
  createdAt  DateTime @default(now()) @map("created_at")

  deployments Deployment[]
  executions  AgentExecution[]
}

model Deployment {
  id           String    @id @default(cuid())
  agentId      String    @map("agent_id")
  agent        Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  versionId    String?   @map("version_id")
  version      AgentVersion? @relation(fields: [versionId], references: [id])
  gitCommit    String?   @map("git_commit")
  imageTag     String?   @map("image_tag")
  status       String    @default("pending")
  resultLog    String?   @map("result_log")
  deployedAt   DateTime? @map("deployed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  // V2.0 新增字段
  slot         String    @default("blue")
  trafficWeight Int     @default(100) @map("traffic_weight")
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  deployedBy   String?   @map("deployed_by")
  triggerSource String   @default("manual") @map("trigger_source")
  rollbackFromId String?  @map("rollback_from_id")
}

model AgentExecution {
  id           String       @id @default(cuid())
  agentId      String       @map("agent_id")
  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  versionId    String?      @map("version_id")
  version      AgentVersion? @relation(fields: [versionId], references: [id])
  requestId    String       @unique @map("request_id")
  userId       String?      @map("user_id")
  user         User?        @relation(fields: [userId], references: [id])
  inputTokens  Int          @default(0) @map("input_tokens")
  outputTokens Int          @default(0) @map("output_tokens")
  totalTokens  Int          @default(0) @map("total_tokens")
  cost         Float        @default(0)
  latencyMs    Int          @default(0) @map("latency_ms")
  status       String       @default("pending")
  errorMsg     String?      @map("error_msg")
  createdAt    DateTime     @default(now()) @map("created_at")
}

model AgentHealth {
  id            String    @id @default(cuid())
  agentId       String    @map("agent_id")
  agent         Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status        String    @default("offline")
  uptime        Int       @default(0)
  memoryMb      Float     @default(0) @map("memory_mb")
  cpuPercent    Float     @default(0) @map("cpu_percent")
  restartCount  Int       @default(0) @map("restart_count")
  lastHeartbeat DateTime? @map("last_heartbeat")
  createdAt     DateTime  @default(now()) @map("created_at")
}

// V2.0 新增表
model HealthCheckLog {
  id            String   @id @default(cuid())
  agentId       String   @map("agent_id")
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status        String   // healthy | unhealthy | timeout
  responseTimeMs Int     @default(0) @map("response_time_ms")
  statusCode    Int?     @map("status_code")
  error         String?
  checkedAt     DateTime @default(now()) @map("checked_at")

  @@index([agentId, checkedAt])
}

model Alert {
  id          String    @id @default(cuid())
  agentId     String    @map("agent_id")
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type        String    // health | deployment | cost
  severity    String    // info | warning | critical
  message     String
  resolved    Boolean   @default(false)
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([agentId, createdAt])
  @@index([resolved, severity])
}

model ApiKey {
  id          String    @id @default(cuid())
  agentId     String    @map("agent_id")
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  keyHash     String    @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  name        String?
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([agentId])
}

model AlertRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  metric      String
  operator    String
  threshold   Float
  duration    Int      @default(5)
  agentId     String?  @map("agent_id")
  agent       Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  global      Boolean  @default(false)
  severity    String   @default("warning")
  channels    String   @default("[]")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([agentId])
  @@index([enabled])
}

model McpTool {
  id          String   @id @default(cuid())
  agentId     String   @map("agent_id")
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name        String
  description String
  inputSchema String   @map("input_schema")
  endpoint    String
  method      String   @default("POST")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([agentId])
  @@index([name])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  type        String   @default("fastapi")
  icon        String   @default("bot")
  tags        String   @default("[]")
  githubRepo  String   @default("")
  githubBranch String  @default("main") @map("github_branch")
  variables   String   @default("[]")
  files       String   @default("[]")
  forkCount   Int      @default(0) @map("fork_count")
  usageCount  Int      @default(0) @map("usage_count")
  iterationVersion Int @default(1) @map("iteration_version")
  iterationNotes   String? @map("iteration_notes")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  agents      Agent[]
  agentTemplates AgentTemplate[]
}

model AgentTemplate {
  id         String   @id @default(cuid())
  agentId    String   @map("agent_id")
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  templateId String   @map("template_id")
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  variables  String   @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  
  @@unique([agentId, templateId])
}

model Workflow {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  status          String   @default("draft")
  nodes           String   @default("[]")
  edges           String   @default("[]")
  variables       String   @default("{}")
  executionCount  Int      @default(0) @map("execution_count")
  successCount    Int      @default(0) @map("success_count")
  failureCount    Int      @default(0) @map("failure_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  executions      WorkflowExecution[]
}

model WorkflowNode {
  id          String   @id @default(cuid())
  workflowId  String   @map("workflow_id")
  nodeId      String   @map("node_id")
  type        String
  label       String
  config      String   @default("{}")
  agentId     String?  @map("agent_id")
  agent       Agent?   @relation(fields: [agentId], references: [id])
  positionX   Float    @default(0) @map("position_x")
  positionY   Float    @default(0) @map("position_y")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([workflowId])
  @@index([agentId])
}

model WorkflowExecution {
  id          String    @id @default(cuid())
  workflowId  String    @map("workflow_id")
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status      String    @default("running")
  input       String?
  output      String?
  nodeResults String    @default("[]") @map("node_results")
  error       String?
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  durationMs  Int?      @map("duration_ms")
  
  @@index([workflowId])
  @@index([status])
}
