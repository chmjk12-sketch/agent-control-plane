# 数据库配置 (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/agent_control_plane?schema=public

# OpenAI API 配置
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=

# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 控制平面自身地址（用于 deploy-notify 回调）
SELF_URL=https://administrator.chmjk67.top

# deploy-notify 回调鉴权密钥
CP_NOTIFY_SECRET=your-random-secret-here

# Redis 配置（用于缓存和分布式锁）
REDIS_URL=redis://localhost:6379/0

# Grafana 配置
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# CrewAI 服务配置
CREWAI_SERVICE_URL=http://crewai-service:8000
DEFAULT_LLM=deepseek-chat

# 工作流配置
WORKFLOW_MAX_CONCURRENT=5
WORKFLOW_TIMEOUT_MS=120000

# 告警配置
ALERT_DEFAULT_CHANNELS=["webhook"]
ALERT_WEBHOOK_URL=

# 环境
NODE_ENV=production

# GitHub 配置（用于模板 Fork 和仓库管理）
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_ORG=your-github-org-name

# 通知密钥
NOTIFY_WEBHOOK_URL=https://hooks.example.com/notify
