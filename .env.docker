# ===========================================
# Docker Compose 环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.docker .env
# ===========================================

# ---- 构建配置 ----
# Docker 镜像 tag（默认 latest）
IMAGE_TAG=

# ---- PostgreSQL 配置 ----
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ---- 应用环境变量 ----
# 数据库连接 URL（docker-compose 会自动拼接，此项可留空）
DATABASE_URL=

# OpenAI API
OPENAI_API_KEY=
OPENAI_BASE_URL=

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# 控制平面自身地址（用于 deploy-notify 回调）
SELF_URL=https://administrator.chmjk67.top

# deploy-notify 回调鉴权密钥
CP_NOTIFY_SECRET=

# Redis 配置（用于缓存和分布式锁）
REDIS_URL=

# Node 环境
NODE_ENV=production
